# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
# Local LOG_LEVEL=debug
# Production server LOG_LEVEL=info
# Tests LOG_LEVEL=silent

# --- Swagger / OpenAPI ------------------------------------------------------
SWAGGER_ENABLED=true
PUBLIC_API_URL=http://localhost:3000

# --- Database (Prisma / PostgreSQL) -----------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL=postgresql://

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Rate limit -------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW="1 minute"

# --- CORS -------------------------------------------------------------------
# Comma-separated list. Use "*" to allow any origin (not recommended in prod).
CORS_ORIGINS=http://localhost:5173

# --- Graceful shutdown ------------------------------------------------------
FASTIFY_CLOSE_GRACE_DELAY=500

# --- Telegram Bot Config ----------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
ADMIN_CHAT_ID=

# --- Bot Connection Options (polling or webhook) ----------------------------
TELEGRAM_BOT_MODE=polling
TELEGRAM_WEBHOOK_URL=

# --- Frontend Launch Target (React app URL loaded by Telegram WebApp button) -
TELEGRAM_MINI_APP_URL=http://localhost:5173
